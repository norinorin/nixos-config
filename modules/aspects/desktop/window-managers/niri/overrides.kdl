include "hm.kdl"

input {
    tablet {
        map-to-output "HDMI-A-1"
    }
}

window-rule {
    geometry-corner-radius 12

    clip-to-geometry true
}

debug {
    honor-xdg-activation-with-invalid-serial
}

output "HDMI-A-1" {
    mode "1920x1080@180.003"
    scale 1
    position x=0 y=0
}

output "eDP-1" {
    mode "1920x1080@144.001"
    scale 1
    position x=1920 y=0
}

